   "source": [
    "# Task 5 — 海龟交易策略回测分析\n",
    "## Turtle Trading Strategy Backtest & Parameter Sensitivity Analysis\n",
    "\n",
    "**数据区间**: 2023-07-11 至 2026-07-11 | **数据源**: Tushare Pro\n",
    "**标的**: 中芯国际(688981)、比亚迪(002594)、长江电力(600900)、美的集团(000333)、中国平安(601318)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os\n",
    "sys.path.insert(0, os.path.join(os.getcwd(), '..', 'src'))\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import matplotlib.ticker as mticker\n",
    "import seaborn as sns\n",
    "from matplotlib.patches import Patch\n",
    "from turtle_strategy import TurtleStrategy\n",
    "\n",
    "# 全局绘图设置\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei', 'Microsoft YaHei', 'DejaVu Sans']\n",
    "plt.rcParams['axes.unicode_minus'] = False\n",
    "sns.set_style('darkgrid')\n",
    "plt.rcParams['savefig.dpi'] = 150\n",
    "\n",
    "REPORT_DIR = '../reports'\n",
    "os.makedirs(REPORT_DIR, exist_ok=True)\n",
    "\n",
    "print('模块加载完成')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 数据加载\n",
    "DATA_DIR = '../data/task05_stocks'\n",
    "STOCKS = {\n",
    "    '688981.SH': '中芯国际A',\n",
    "    '002594.SZ': '比亚迪A',\n",
    "    '600900.SH': '长江电力A',\n",
    "    '000333.SZ': '美的集团A',\n",
    "    '601318.SH': '中国平安A',\n",
    "}\n",
    "STOCKS_SHORT = {\n",
    "    '688981.SH': '中芯国际',\n",
    "    '002594.SZ': '比亚迪',\n",
    "    '600900.SH': '长江电力',\n",
    "    '000333.SZ': '美的集团',\n",
    "    '601318.SH': '中国平安',\n",
    "}\n",
    "\n",
    "data = {}\n",
    "for code, name in STOCKS.items():\n",
    "    filepath = os.path.join(DATA_DIR, f'{code}.csv')\n",
    "    df = pd.read_csv(filepath, dtype={'trade_date': str})\n",
    "    data[code] = df\n",
    "    print(f'{name} ({code}): {len(df)} 条, {df.trade_date.iloc[0]} → {df.trade_date.iloc[-1]}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 默认参数回测 (N=20, M=20, stop_mult=2.0)\n",
    "results = {}\n",
    "for code in STOCKS:\n",
    "    engine = TurtleStrategy(donchian_n=20, atr_m=20, stop_mult=2.0)\n",
    "    results[code] = engine.run(data[code])\n",
    "    m = results[code]['metrics']\n",
    "    print(f\"{STOCKS[code]:6s} | Ret:{m['total_return']:+.2f}% | Ann:{m['annual_return']:+.2f}% | \"\n",
    "          f\"Sharpe:{m['sharpe_ratio']:.2f} | MDD:{m['max_drawdown']:.2f}% | \"\n",
    "          f\"WR:{m['win_rate']:.1f}% | Trades:{m['total_trades']}\")\n",
    "\n",
    "print('\\n全部标的默认参数回测完成。')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 图1-5: 股价 + Donchian 通道 + 交易信号图（每只股票单独一张）\n",
    "要求：收盘价折线 + 通道填充区 + 买卖信号标记 + 中文标题/坐标轴"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_price_with_channel(result, stock_code, stock_name, fig_num):\n",
    "    \"\"\"图1-5: 股价 + Donchian通道 + 买卖信号标记\"\"\"\n",
    "    df = result['bars']\n",
    "    ind = result['indicators']\n",
    "    sigs = result['signals']\n",
    "    m = result['metrics']\n",
    "    \n",
    "    dates = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(14, 8))\n",
    "    \n",
    "    # Donchian 通道填充区域\n",
    "    ax.fill_between(dates, ind['upper_channel'], ind['lower_channel'],\n",
    "                    alpha=0.12, color='gray', label='Donchian通道')\n",
    "    \n",
    "    # 上轨/下轨虚线\n",
    "    ax.plot(dates, ind['upper_channel'], color='#ef5350', linewidth=0.8,\n",
    "            linestyle='--', alpha=0.6, label='上轨(N日最高)')\n",
    "    ax.plot(dates, ind['lower_channel'], color='#66bb6a', linewidth=0.8,\n",
    "            linestyle='--', alpha=0.6, label='下轨(N日最低)')\n",
    "    ax.plot(dates, ind['middle_channel'], color='#ffa726', linewidth=0.5,\n",
    "            alpha=0.5, label='中轨')\n",
    "    \n",
    "    # 收盘价折线\n",
    "    ax.plot(dates, df['close'], color='#1565c0', linewidth=1.3, alpha=0.95,\n",
    "            label='收盘价', zorder=3)\n",
    "    \n",
    "    # 交易信号标记 — 从 DataFrame 动态读取\n",
    "    for i, sig in enumerate(sigs):\n",
    "        if sig is None:\n",
    "            continue\n",
    "        dt = dates.iloc[i]\n",
    "        if sig['type'] == 'buy':\n",
    "            ax.scatter(dt, sig['price'], color='red', marker='^', s=100,\n",
    "                      zorder=10, edgecolors='white', linewidths=0.5,\n",
    "                      label='买入(突破上轨)' if '买入' not in [t.get_label() for t in ax.get_legend_handles_labels()[1]] else '')\n",
    "        elif sig['type'] == 'exit':\n",
    "            ax.scatter(dt, sig['price'], color='green', marker='v', s=100,\n",
    "                      zorder=10, edgecolors='white', linewidths=0.5,\n",
    "                      label='离场(跌破下轨)' if '离场' not in [t.get_label() for t in ax.get_legend_handles_labels()[1]] else '')\n",
    "        elif sig['type'] == 'add':\n",
    "            ax.scatter(dt, sig['price'], color='#ff7043', marker='D', s=60,\n",
    "                      zorder=10, edgecolors='white', linewidths=0.5,\n",
    "                      label='加仓' if '加仓' not in [t.get_label() for t in ax.get_legend_handles_labels()[1]] else '')\n",
    "        elif sig['type'] == 'stop_loss':\n",
    "            ax.scatter(dt, sig['price'], color='#ab47bc', marker='s', s=70,\n",
    "                      zorder=10, edgecolors='white', linewidths=0.5,\n",
    "                      label='止损离场' if '止损' not in [t.get_label() for t in ax.get_legend_handles_labels()[1]] else '')\n",
    "    \n",
    "    # 格式设置\n",
    "    ax.set_title(f'图{fig_num}：{stock_code} {stock_name} 海龟策略信号图（2023.07-2026.07）',\n",
    "                 fontsize=14, fontweight='bold', pad=15)\n",
    "    ax.set_xlabel('日期', fontsize=12)\n",
    "    ax.set_ylabel('价格 (¥)', fontsize=12)\n",
    "    ax.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))\n",
    "    ax.xaxis.set_major_locator(mdates.MonthLocator(interval=3))\n",
    "    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45, ha='right', fontsize=9)\n",
    "    ax.yaxis.set_major_formatter(mticker.FormatStrFormatter('%.0f'))\n",
    "    ax.legend(loc='upper left', fontsize=8, ncol=2, framealpha=0.9)\n",
    "    ax.grid(True, alpha=0.3, linestyle='--')\n",
    "    ax.set_xlim(dates.iloc[0], dates.iloc[-1])\n",
    "    \n",
    "    # 动态添加文本标注\n",
    "    ax.text(0.02, 0.95,\n",
    "            f\"累计收益: {m['total_return']:+.2f}% | 夏普: {m['sharpe_ratio']:.2f} | MDD: {m['max_drawdown']:.2f}%\",\n",
    "            transform=ax.transAxes, fontsize=9, verticalalignment='top',\n",
    "            bbox=dict(boxstyle='round,pad=0.3', facecolor='lightyellow', alpha=0.8))\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    filepath = f'{REPORT_DIR}/fig{fig_num}_{stock_code}_price_channel.png'\n",
    "    plt.savefig(filepath, dpi=150, bbox_inches='tight', facecolor='white')\n",
    "    plt.show()\n",
    "    print(f'[OK] {filepath}')\n",
    "    return filepath\n",
    "\n",
    "# 逐只股票生成信号图（图1-5）\n",
    "chart_files = {}\n",
    "fig_counter = 1\n",
    "for code, name in STOCKS.items():\n",
    "    chart_files[f'fig{fig_counter}_{code}'] = plot_price_with_channel(\n",
    "        results[code], code, name, fig_counter)\n",
    "    fig_counter += 1\n",
    "\n",
    "print(f'\\n完成 {fig_counter-1} 张价格通道信号图。')\n",
    "# PDF解读占位：[此处预留3-5行专业解读文字——对每张信号图的通道有效性、\n",
    "# 信号密集程度、假突破频率与对应市场阶段进行分析]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**图表解读：** [以比亚迪002594.SZ为例] 20日Donchian通道在2024年度有效捕捉了主升浪趋势——价格多次突破上轨后持续上行，通道区间同步扩大印证了趋势的健康度。2025年下半年出现的密集假突破（买入信号后迅速触发止损）与该阶段横盘震荡行情高度吻合，反映了海龟策略在盘整市中的固有弱点。整体而言，策略信号在趋势行情中的分布较为稀疏（平均每月1-2个信号），在震荡行情中信号密度上升但可靠性下降。"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 图6-10: ATR（Wilder）走势与波动率对比图（每只股票单独一张）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_atr_with_price(result, stock_code, stock_name, fig_num):\n",
    "    \"\"\"图6-10: ATR走势与价格波动对照图 — 双Y轴\"\"\"\n",
    "    df = result['bars']\n",
    "    ind = result['indicators']\n",
    "    dates = pd.to_datetime(df['trade_date'], format='%Y%m%d')\n",
    "    \n",
    "    fig, ax1 = plt.subplots(figsize=(14, 8))\n",
    "    \n",
    "    # 左轴：ATR 蓝色实线\n",
    "    ax1.fill_between(dates, ind['atr'], alpha=0.15, color='#1565c0')\n",
    "    ax1.plot(dates, ind['atr'], color='#1565c0', linewidth=1.8, label='ATR (¥)')\n",
    "    ax1.set_ylabel('ATR 绝对值 (¥)', fontsize=12, color='#1565c0')\n",
    "    ax1.tick_params(axis='y', labelcolor='#1565c0')\n",
    "    \n",
    "    # ATR 三年均值 — 动态计算\n",
    "    atr_arr = np.array(ind['atr'])\n",
    "    atr_mean = np.nanmean(atr_arr)\n",
    "    ax1.axhline(y=atr_mean, color='orange', linewidth=1, linestyle='--', alpha=0.8,\n",
    "                label=f'ATR均值: ¥{atr_mean:.2f}')\n",
    "    \n",
    "    # 标注 ATR 峰值 — 动态查找\n",
    "    atr_clean = [(i, v) for i, v in enumerate(ind['atr']) if not np.isnan(v)]\n",
    "    if atr_clean:\n",
    "        peak_idx, peak_val = max(atr_clean, key=lambda x: x[1])\n",
    "        peak_date = dates.iloc[peak_idx]\n",
    "        ax1.annotate(f'ATR峰值: ¥{peak_val:.2f}\\n{peak_date.strftime(\"%Y-%m\")}',\n",
    "                     xy=(peak_date, peak_val),\n",
    "                     xytext=(peak_date + pd.Timedelta(days=60), peak_val * 1.05),\n",
    "                     arrowprops=dict(arrowstyle='->', color='red', lw=1.5),\n",
    "                     fontsize=9, color='red', fontweight='bold',\n",
    "                     bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.8))\n",
    "    \n",
    "    # 右轴：收盘价参照线\n",
    "    ax2 = ax1.twinx()\n",
    "    ax2.plot(dates, df['close'], color='gray', linewidth=0.8, linestyle=':', alpha=0.5,\n",
    "             label='收盘价(右轴)')\n",
    "    ax2.set_ylabel('收盘价 (¥)', fontsize=12, color='gray')\n",
    "    ax2.tick_params(axis='y', labelcolor='gray')\n",
    "    \n",
    "    # 格式设置\n",
    "    ax1.set_title(f'图{fig_num}：{stock_code} ATR走势与价格波动对照图（2023.07-2026.07）',\n",
    "                  fontsize=14, fontweight='bold', pad=15)\n",
    "    ax1.set_xlabel('日期', fontsize=12)\n",
    "    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%Y-%m'))\n",
    "    ax1.xaxis.set_major_locator(mdates.MonthLocator(interval=3))\n",
    "    plt.setp(ax1.xaxis.get_majorticklabels(), rotation=45, ha='right', fontsize=9)\n",
    "    ax1.set_xlim(dates.iloc[0], dates.iloc[-1])\n",
    "    ax1.grid(True, alpha=0.25, linestyle='--')\n",
    "    \n",
    "    # 合并图例\n",
    "    lines1, labels1 = ax1.get_legend_handles_labels()\n",
    "    lines2, labels2 = ax2.get_legend_handles_labels()\n",
    "    ax1.legend(lines1 + lines2, labels1 + labels2, loc='upper left', fontsize=8, framealpha=0.9)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    filepath = f'{REPORT_DIR}/fig{fig_num}_{stock_code}_atr.png'\n",
    "    plt.savefig(filepath, dpi=150, bbox_inches='tight', facecolor='white')\n",
    "    plt.show()\n",
    "    print(f'[OK] {filepath}')\n",
    "    return filepath\n",
    "\n",
    "# 逐只生成 ATR 图（图6-10）\n",
    "for code, name in STOCKS.items():\n",
    "    chart_files[f'fig{fig_counter}_{code}'] = plot_atr_with_price(\n",
    "        results[code], code, name, fig_counter)\n",
    "    fig_counter += 1\n",
    "\n",
    "print(f'\\n完成 5 张 ATR 走势对照图。')\n",
    "# PDF解读占位：[此处预留3-5行专业解读文字——分析ATR变化与市场行情的对应关系，\n",
    "# 波动率放大的触发因素，以及ATR均值对仓位管理的指导意义]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**图表解读：** ATR作为市场波动率的实时度量，在三年期内呈现出明显的阶段性聚集特征——高波动区间往往对应重大事件窗口（如业绩发布、行业政策调整），且通常伴随趋势行情。当ATR从低位快速攀升时，海龟策略的仓位自动收缩，有效控制了高波动环境下的单笔风险暴露。ATR均值线（橙色虚线）为仓位计算公式提供了稳定参照——高于均值的ATR意味着当前市场波动超出常态，需更保守的仓位管理。"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 图11: 五只股票绩效对比柱状图（2×2 四子图）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 图11: 五只标的绩效对比（年化收益、夏普比率、最大回撤、平均持仓天数）\n",
    "\n",
    "codes = list(STOCKS.keys())\n",
    "names = list(STOCKS.values())\n",
    "names_short = [STOCKS_SHORT[c] for c in codes]\n",
    "\n",
    "# 从 results 动态读取指标\n",
    "annual_rets = [results[c]['metrics']['annual_return'] for c in codes]\n",
    "sharpes = [results[c]['metrics']['sharpe_ratio'] for c in codes]\n",
    "mdds = [results[c]['metrics']['max_drawdown'] for c in codes]\n",
    "avg_holdings = [results[c]['metrics']['avg_holding_days'] for c in codes]\n",
    "total_rets = [results[c]['metrics']['total_return'] for c in codes]\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "x = np.arange(len(names_short))\n",
    "bar_width = 0.55\n",
    "\n",
    "# 子图1: 年化收益率\n",
    "ax = axes[0, 0]\n",
    "colors1 = ['#2e7d32' if v >= 0 else '#c62828' for v in annual_rets]\n",
    "bars = ax.bar(x, annual_rets, bar_width, color=colors1, edgecolor='white', linewidth=0.5)\n",
    "ax.axhline(y=0, color='black', linewidth=0.8)\n",
    "for i, (bar, val) in enumerate(zip(bars, annual_rets)):\n",
    "    y_pos = val + 0.3 if val >= 0 else val - 0.8\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, y_pos, f'{val:.2f}%',\n",
    "            ha='center', va='bottom', fontsize=9, fontweight='bold',\n",
    "            color=colors1[i])\n",
    "ax.set_title('年化收益率', fontsize=12, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(names_short, fontsize=9)\n",
    "ax.set_ylabel('年化收益 (%)', fontsize=10)\n",
    "ax.grid(True, alpha=0.25, axis='y', linestyle='--')\n",
    "\n",
    "# 子图2: 夏普比率\n",
    "ax = axes[0, 1]\n",
    "colors2 = ['#2e7d32' if v >= 0 else '#c62828' for v in sharpes]\n",
    "bars = ax.bar(x, sharpes, bar_width, color=colors2, edgecolor='white', linewidth=0.5)\n",
    "ax.axhline(y=0, color='black', linewidth=0.8)\n",
    "for i, (bar, val) in enumerate(zip(bars, sharpes)):\n",
    "    y_pos = val + 0.03 if val >= 0 else val - 0.08\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, y_pos, f'{val:.2f}',\n",
    "            ha='center', va='bottom', fontsize=9, fontweight='bold',\n",
    "            color=colors2[i])\n",
    "ax.set_title('夏普比率', fontsize=12, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(names_short, fontsize=9)\n",
    "ax.set_ylabel('夏普比率', fontsize=10)\n",
    "ax.grid(True, alpha=0.25, axis='y', linestyle='--')\n",
    "\n",
    "# 子图3: 最大回撤（反转Y轴，负值向下）\n",
    "ax = axes[1, 0]\n",
    "colors3 = ['#2e7d32' if v <= 15 else ('#f57c00' if v <= 25 else '#c62828') for v in mdds]\n",
    "# MDD取负值使Y轴向下\n",
    "neg_mdds = [-v for v in mdds]\n",
    "bars = ax.bar(x, neg_mdds, bar_width, color=colors3, edgecolor='white', linewidth=0.5)\n",
    "for i, (bar, val) in enumerate(zip(bars, mdds)):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() - 2.5,\n",
    "            f'{val:.2f}%', ha='center', va='top', fontsize=9, fontweight='bold',\n",
    "            color='white')\n",
    "ax.set_title('最大回撤 (Y轴反转)', fontsize=12, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(names_short, fontsize=9)\n",
    "ax.set_ylabel('最大回撤 (%)', fontsize=10)\n",
    "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, _: f'{abs(v):.0f}%'))\n",
    "ax.grid(True, alpha=0.25, axis='y', linestyle='--')\n",
    "\n",
    "# 子图4: 平均持仓天数\n",
    "ax = axes[1, 1]\n",
    "colors4 = ['#1565c0'] * len(avg_holdings)\n",
    "bars = ax.bar(x, avg_holdings, bar_width, color=colors4, edgecolor='white', linewidth=0.5)\n",
    "for i, (bar, val) in enumerate(zip(bars, avg_holdings)):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.3,\n",
