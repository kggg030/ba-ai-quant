    "def plot_sensitivity_heatmap(grid, stock_code, stock_name, fig_num):\n",
    "    \"\"\"图12-16: 参数敏感性热力图 — 夏普比率\"\"\"\n",
    "    fig, ax = plt.subplots(figsize=(12, 6))\n",
    "    \n",
    "    # 热力图\n",
    "    im = ax.imshow(grid, cmap='RdYlGn', aspect='auto', vmin=-0.5, vmax=1.5)\n",
    "    \n",
    "    # 轴标签\n",
    "    ax.set_xticks(range(len(N_range)))\n",
    "    ax.set_xticklabels([f'N={n}' for n in N_range], fontsize=10)\n",
    "    ax.set_yticks(range(len(M_range)))\n",
    "    ax.set_yticklabels([f'M={m}' for m in M_range], fontsize=10)\n",
    "    ax.set_xlabel('Donchian 通道周期 N →', fontsize=12, fontweight='bold')\n",
    "    ax.set_ylabel('ATR 周期 M →', fontsize=12, fontweight='bold')\n",
    "    \n",
    "    # 单元格数值标注 — 白色字体，最优值加粗\n",
    "    best_idx = np.unravel_index(np.argmax(grid), grid.shape)\n",
    "    for i in range(len(M_range)):\n",
    "        for j in range(len(N_range)):\n",
    "            val = grid[i, j]\n",
    "            is_best = (i == best_idx[0] and j == best_idx[1])\n",
    "            text_color = 'white'\n",
    "            fontweight = 'bold' if is_best else 'normal'\n",
    "            ax.text(j, i, f'{val:.2f}', ha='center', va='center',\n",
    "                   fontsize=10, color=text_color, fontweight=fontweight)\n",
    "    \n",
    "    # Colorbar\n",
    "    cbar = plt.colorbar(im, ax=ax, shrink=0.85, pad=0.02)\n",
    "    cbar.set_label('Sharpe Ratio', fontsize=11, fontweight='bold')\n",
    "    \n",
    "    ax.set_title(f'图{fig_num}：{stock_code} {stock_name} 参数敏感性热力图（夏普比率）',\n",
    "                fontsize=14, fontweight='bold', pad=15)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    filepath = f'{REPORT_DIR}/fig{fig_num}_{stock_code}_sensitivity.png'\n",
    "    plt.savefig(filepath, dpi=150, bbox_inches='tight', facecolor='white')\n",
    "    plt.show()\n",
    "    print(f'[OK] {filepath}')\n",
    "    return filepath\n",
    "\n",
    "# 逐只生成热力图（图12-16）\n",
    "for code, name in STOCKS.items():\n",
    "    chart_files[f'fig{fig_counter}_{code}'] = plot_sensitivity_heatmap(\n",
    "        sensitivity[code]['sharpe'], code, name, fig_counter)\n",
    "    fig_counter += 1\n",
    "\n",
    "print(f'\\n完成 5 张参数敏感性热力图。')\n",
